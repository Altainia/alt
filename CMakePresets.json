{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "ALT_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Standard debug build",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "debug-asan",
      "displayName": "Debug + ASan/UBSan",
      "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ALT_SANITIZE": "address"
      }
    },
    {
      "name": "debug-msan",
      "displayName": "Debug + MSan (Clang only)",
      "description": "Debug build with MemorySanitizer. Requires Clang AND a fully MSan-instrumented libc++ — does not work with the default libstdc++. Not run in CI for this reason.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ALT_SANITIZE": "memory",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "debug-coverage",
      "displayName": "Debug + Coverage (GCC only)",
      "description": "Debug build with gcov coverage instrumentation; requires GCC",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ALT_COVERAGE": "ON",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build without tests",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ALT_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "debug-asan",
      "configurePreset": "debug-asan"
    },
    {
      "name": "debug-msan",
      "configurePreset": "debug-msan"
    },
    {
      "name": "debug-coverage",
      "configurePreset": "debug-coverage"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-asan",
      "configurePreset": "debug-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-msan",
      "configurePreset": "debug-msan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-coverage",
      "configurePreset": "debug-coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
